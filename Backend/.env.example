# Environment Variables

# Asynchronous connection string for FastAPI/SQLAlchemy (using asyncpg).
# Use the exact host from your provider (e.g. Neon: ep-xxx.us-east-2.aws.neon.tech).
# If host cannot be resolved (getaddrinfo failed), check internet and host spelling.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<database>?ssl=require

# Synchronous connection string
SYNC_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Frontend base URL used in invitation + password reset emails
# IMPORTANT: Set this on Railway/Render to your deployed Vercel app URL
FRONTEND_BASE_URL=https://fyp-project-livid.vercel.app

# Optional alias supported by the backend (if you prefer this name in Railway)
PUBLIC_FRONTEND_URL=https://fyp-project-livid.vercel.app

# Optional: first-run user seeding on deploy (creates users only if missing)
SEED_ADMIN_EMAIL=admin@hospital.com
SEED_ADMIN_PASSWORD=123
SEED_DOCTOR_EMAIL=doctor@hospital.com
SEED_DOCTOR_PASSWORD=123
SEED_NURSE_EMAIL=nurse@hospital.com
SEED_NURSE_PASSWORD=123
