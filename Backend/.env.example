# Environment Variables

# Asynchronous connection string for FastAPI/SQLAlchemy (using asyncpg).
# Use the exact host from your provider (e.g. Neon: ep-xxx.us-east-2.aws.neon.tech).
# If host cannot be resolved (getaddrinfo failed), check internet and host spelling.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<database>?ssl=require

# Synchronous connection string
SYNC_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
