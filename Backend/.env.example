# Copy to ".env" in this folder (Backend/) for local development.
# On Railway, set these in the service Environment variables instead.
# Do not commit ".env" or paste real keys into source code.
#
# Used by the Hospital Ops Copilot (OpenAI Agents SDK + Runner).

OPENAI_API_KEY=
OPENAI_OPS_COPILOT_MODEL=gpt-4o-mini
# Optional: raise if briefing hits "Max turns exceeded" (multi-tool runs need more than SDK default 10).
# OPENAI_OPS_COPILOT_MAX_TURNS=40

# Optional: your Vercel site URL (emails + CORS). On Railway, set this to match NEXT_PUBLIC_API_URL’s frontend origin.
# FRONTEND_BASE_URL=https://your-project.vercel.app

# Fresh cloud DB: create admin once at startup if the user row is missing.
# SEED_ADMIN_EMAIL=admin@hospital.com
# SEED_ADMIN_PASSWORD=your-secure-password
